# Base de datos
DB_CONNECTION_STRING=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Auth0
AUTH0_AUDIENCE=KoruDealsApiBackEnd
AUTH0_ISSUER_BASE_URL=https://<tu-dominio>.us.auth0.com/

# Frontend (URL de producción en Render)
FRONTEND_URL=https://<tu-frontend>.onrender.com

# Puerto (Render lo asigna automáticamente)
PORT=3000
